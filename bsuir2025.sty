% ---------------------------------------
% Кастомные команды для вставки рисунков
% ---------------------------------------
\counterwithin{figure}{chapter} 
% Настройка подписей к рисункам: "Рисунок" с длинным тире и обычной нумерацией
\captionsetup[figure]{
  labelformat=default,
  labelsep=endash,
  name=Рисунок,
  skip=15pt,                              % отступ между рисунком и подписью
  belowskip=-8.5pt,                       % отсуп между подписью и текстом
}

% ---------------------------------------
% Настройка подписей к таблице
% ---------------------------------------
% ---------------------------------------
\DeclareCaptionFormat{tableformat}{#1#2#3} 
\renewcommand{\arraystretch}{1.5}       % небольшой отступ между текстом в таблице
\captionsetup[longtable]{
  labelsep=endash,
  name=Таблица,
  justification=raggedright,
  format=tableformat,
  singlelinecheck=false,
  indention=6.3em,                      % Если длинная таблица - перенос по ГОСТ
  hangindent=0pt,
  width=\textwidth,
  skip=0pt,                             % убирает отступ между caption и таблицей
}

% Подпись при разрыве страницы
\newcommand{\longtableheadcontinued}[1]{%
  \multicolumn{#1}{l}{Продолжение таблицы~\thetable} \\[4pt]%
}
% Настройка подписей формул по главам
\counterwithin{equation}{chapter}

% ---------------------------------------------
% Команда для вставки одного изображения с подписью
% Аргументы:
%   #1 — label (метка для ссылки, напр. fig:logo)
%   #2 — путь к изображению
%   #3 — подпись
%   #4 — ширина изображения (напр. 0.8\textwidth)
% ---------------------------------------------
\newcommand{\insertfigure}[4]{%
  \begin{figure}[H]
    \centering
    \includegraphics[width=#4]{#2}
    \caption{#3}
    \label{fig:#1}
  \end{figure}
}

% -----------------------------------------------------------------------------
% Гибкая команда для вставки двух изображений — рядом или друг под другом
% Аргументы:
%   #1 — путь к первому изображению
%   #2 — путь ко второму изображению
%   #3 — ширина одного изображения
%   #4 — подпись
%   #5 — label (метка для ссылки)
%   #6 — режим отображения: sidebyside или stacked
% -----------------------------------------------------------------------------
\newcommand{\insertfigurescustom}[6]{%
  \begin{figure}[H]
    \centering
    \ifthenelse{\equal{#6}{sidebyside}}{%
      \includegraphics[width=#3]{#1}%
      \hspace{1mm}%
      \includegraphics[width=#3]{#2}%
    }{%
      \includegraphics[width=#3]{#1}\par\medskip
      \includegraphics[width=#3]{#2}%
    }
    \captionsetup{justification=centering}
    \caption{#4}
    \label{fig:#5}
  \end{figure}
}

% Команда для ненумерованных разделов (Введение, Заключение и т.д.)
\newcommand{\unnumberedchapter}[2][]{%
  \chapter*{\begin{center}#2\end{center}}%
  \vspace{-1.3\baselineskip}%       
  \addcontentsline{toc}{chapter}{\hspace*{-1em}\ifx&#1&\relax#2\else#1\fi}%
}